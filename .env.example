# Copy to .env for local dev, and set these in Vercel's project settings for prod.
# Without the Upstash vars, the server falls back to a local data/db.json (fine for dev,
# but Vercel's filesystem is ephemeral — production NEEDS Upstash to persist state).

# Admin (route builder) gate
ADMIN_PASSWORD=change-me
# Used to sign session cookies — make this a long random string in prod
SESSION_SECRET=please-change-this-to-something-random
# Optional: how long an admin login lasts (minutes)
# ADMIN_SESSION_MINUTES=120

# Upstash Redis (REST API) — create a free DB at https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
# UPSTASH_REDIS_KEY=milemark-db
